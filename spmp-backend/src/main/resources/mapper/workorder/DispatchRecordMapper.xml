<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spmp.workorder.repository.DispatchRecordMapper">

    <select id="selectByOrderId" resultType="com.spmp.workorder.domain.entity.DispatchRecordDO">
        SELECT * FROM wo_dispatch_record
        WHERE order_id = #{orderId} AND del_flag = 0
        ORDER BY dispatch_time DESC
    </select>

</mapper>
