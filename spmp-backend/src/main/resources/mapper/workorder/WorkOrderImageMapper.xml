<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spmp.workorder.repository.WorkOrderImageMapper">

    <select id="selectByOrderIdAndType" resultType="com.spmp.workorder.domain.entity.WorkOrderImageDO">
        SELECT * FROM wo_work_order_image
        WHERE order_id = #{orderId}
          AND image_type = #{imageType}
        ORDER BY sort_order
    </select>

    <select id="selectByOrderId" resultType="com.spmp.workorder.domain.entity.WorkOrderImageDO">
        SELECT * FROM wo_work_order_image
        WHERE order_id = #{orderId}
        ORDER BY sort_order
    </select>

    <delete id="deleteByOrderId">
        DELETE FROM wo_work_order_image WHERE order_id = #{orderId}
    </delete>

</mapper>
