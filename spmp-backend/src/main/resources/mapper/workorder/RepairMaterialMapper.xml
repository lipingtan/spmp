<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spmp.workorder.repository.RepairMaterialMapper">

    <select id="selectByOrderId" resultType="com.spmp.workorder.domain.entity.RepairMaterialDO">
        SELECT * FROM wo_repair_material
        WHERE order_id = #{orderId}
    </select>

    <delete id="deleteByOrderId">
        DELETE FROM wo_repair_material WHERE order_id = #{orderId}
    </delete>

</mapper>
