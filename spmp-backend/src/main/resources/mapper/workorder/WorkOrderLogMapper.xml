<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spmp.workorder.repository.WorkOrderLogMapper">

    <select id="selectByOrderId" resultType="com.spmp.workorder.domain.entity.WorkOrderLogDO">
        SELECT * FROM wo_work_order_log
        WHERE order_id = #{orderId}
        ORDER BY operate_time ASC
    </select>

</mapper>
