<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spmp.workorder.repository.UrgeRecordMapper">

    <select id="selectByOrderId" resultType="com.spmp.workorder.domain.entity.UrgeRecordDO">
        SELECT * FROM wo_urge_record
        WHERE order_id = #{orderId}
        ORDER BY urge_time DESC
    </select>

</mapper>
