{
  "name": "spmp-web-pc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "lint:id-input": "node scripts/check-no-id-input.mjs",
    "quality": "npm run lint:id-input && npm run lint",
    "format": "prettier --write \"src/**/*.{vue,ts,js,jsx,tsx,css,json}\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.7.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.27",
    "vue-i18n": "^9.13.1",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.19",
    "vitest": "^2.1.9"
  }
}
